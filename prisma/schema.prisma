// Prisma schema — Phase 1 DATA-01 relational foundation.
// Datasource uses the pooled DATABASE_URL for app traffic (serverless-safe,
// connection_limit=1 set in the URL value) and DIRECT_URL for migrations only.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled: ...?pgbouncer=true&connection_limit=1
  directUrl = env("DIRECT_URL")   // direct connection: migrations only
}

enum Role {
  Admin
  Operator
}

// Defined up front so the Phase-8 importer can normalize legacy mixed-case statuses.
enum JobStatus {
  queued
  submitted
  in_queue
  in_progress
  completed
  failed
  cancelled
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(Operator)
  disabled     Boolean  @default(false)
  createdAt    DateTime @default(now())
}

// Admin-editable domain tables (NOT enums — PROJECT.md requires editability)
model CameraView {
  id        String @id @default(cuid())
  key       String @unique
  label     String
  azimuth   Float
  elevation Float
  focalMm   Float
  fStop     Float
}

model Metal {
  id    String  @id @default(cuid())
  key   String  @unique
  label String
  hex   String?
}

model StoneType {
  id     String @id @default(cuid())
  key    String @unique
  label  String
  preset Json?
}

model ObjectGroup {
  id        String @id @default(cuid())
  key       String @unique
  label     String
  sortOrder Int    @default(0)
}

model QualityPreset {
  id      String @id @default(cuid())
  key     String @unique
  label   String
  samples Int
  width   Int    @default(1920)
  height  Int    @default(1920)
}

// Core relational stubs (full use in later phases; created now so the model is stable — DATA-01)
model Project {
  id        String    @id @default(cuid())
  name      String
  createdAt DateTime  @default(now())
  products  Product[]
}

model Product {
  id            String                  @id @default(cuid())
  projectId     String?
  project       Project?                @relation(fields: [projectId], references: [id])
  name          String
  modelUrl      String?
  modelFormat   String?
  inspectionUrl String?
  // Phase 2 status value convention: needs_inspection|inspecting|needs_groups|ready|inspection_failed
  status        String                  @default("draft")
  createdAt     DateTime                @default(now())
  assignments   ObjectGroupAssignment[]
  batches       Batch[]
  inspections   Inspection[]
}

// Phase 2 PROD-02 — material inspection record. Deliberately NOT a Job (Job.batchId
// is required, non-null; an inspection has no batch). status value convention:
// in_queue|in_progress|completed|failed. `inventory` holds the parsed
// inspect_materials.py output (MESH objects + materials).
model Inspection {
  id          String    @id @default(cuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  runpodJobId String?
  status      String    @default("in_queue")
  inventory   Json?
  error       String?
  createdAt   DateTime  @default(now())
  finishedAt  DateTime?

  @@index([productId])
}

model ObjectGroupAssignment {
  id           String   @id @default(cuid())
  productId    String
  product      Product  @relation(fields: [productId], references: [id])
  group        String
  objectTokens String[]
}

model Batch {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  createdById String?
  status      String   @default("draft")
  matrix      Json?
  jobCount    Int      @default(0)
  createdAt   DateTime @default(now())
  // ORCH-05: distinguishes a batch in the "cancelling" transition from a settled
  // cancelled state. Batch status itself stays a derived String (A4), never stored.
  cancelRequestedAt DateTime?
  jobs        Job[]
}

model Job {
  id           String    @id @default(cuid())
  batchId      String
  batch        Batch     @relation(fields: [batchId], references: [id])
  status       JobStatus @default(queued)
  runpodJobId  String? // Phase-8 backfill: upsert legacy jobs by RunPod id
  recipe       Json?
  combo        Json?
  attempt      Int       @default(0)
  error        String?
  outputPrefix String?
  submittedAt  DateTime?
  finishedAt   DateTime?
  // ORCH-02/04: persists the webhook `output` so Phase 5 reads layers from the DB
  // without re-fetching RunPod.
  result            Json?
  // ORCH-04: render start timestamp for live duration in the monitor.
  startedAt         DateTime?
  // ORCH-05: distinguishes "cancelling" from a settled "cancelled" state.
  cancelRequestedAt DateTime?
  layers       Layer[]

  @@index([batchId, status])
}

model Layer {
  id          String  @id @default(cuid())
  // T-05-01: one job = exactly one layer (expand.ts emits one row per
  // angle×metal×pass; handler.py uploads exactly one image per job). @unique
  // makes prisma.layer.upsert({where:{jobId}}) race-free against duplicate/late webhooks.
  jobId       String  @unique
  job         Job     @relation(fields: [jobId], references: [id])
  pass        String
  format      String
  url         String
  metadataUrl String?
  isFlattened Boolean @default(false)
}
