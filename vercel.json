{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "functions": {
    "app/api/products/[id]/ai-analyze/route.ts": {
      "maxDuration": 300
    },
    "app/api/**/*.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    { "path": "/api/cron/dispatch", "schedule": "* * * * *" },
    { "path": "/api/cron/reconcile", "schedule": "* * * * *" }
  ]
}

