# RunPod GPU rendering
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=

# Vercel Blob (binary assets only; new writes private per SEC-02)
BLOB_READ_WRITE_TOKEN=
BLOB_ACCESS=public

# Database — Railway Postgres 16
# DATABASE_URL: pooled, serverless-safe (pgbouncer=true&connection_limit=1)
# DIRECT_URL: direct connection, migrations only
DATABASE_URL=
DIRECT_URL=

# Auth.js v5 — generate with `npx auth secret`
AUTH_SECRET=

# RunPod status webhook shared secret (SEC-04)
RUNPOD_WEBHOOK_SECRET=

# First Admin user seed (never commit real values)
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
